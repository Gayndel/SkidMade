        local stats = slotFolder:FindFirstChild("Stats"); if not stats then return end
        local maxStats = slotFolder:FindFirstChild("MaxStats"); if not maxStats then return end
        local lines = {}
        for _, s in pairs(stats:GetChildren()) do
            local max = maxStats:FindFirstChild(s.Name)
