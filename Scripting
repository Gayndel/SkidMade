-- ═══ TP ANTI-CONTEST ═══
local function setupTPForChar(char)
    local root = char:WaitForChild("HumanoidRootPart", 5)
    if not root then return end
    local savedCF, isTPd = nil, false
    local holdUntil = 0
    local tpStamp = 0

    local function forcePosition(cf)
        root.Anchored = true
        root.CFrame = cf
    end

    local function restore()
        if not isTPd then return end
        isTPd = false
        root.Anchored = false
        if savedCF then root.CFrame = savedCF end
        savedCF = nil
    end

    local holdConn
    holdConn = RunService.Heartbeat:Connect(function()
        if isTPd and savedCF then
            if tick() < holdUntil then
                forcePosition(savedCF + Vector3.new(0, Flags.TPHeight, 0))
            else
                restore()
            end
        end
    end)

    local c1 = char:GetAttributeChangedSignal("Action"):Connect(function()
        if not Flags.TPAntiContest then return end
        local a = char:GetAttribute("Action") or ""
        if (a == "Shooting" or a == "Dunking") and not isTPd then
            savedCF = root.CFrame
            tpStamp = tick()
            holdUntil = math.huge
            isTPd = true
            forcePosition(savedCF + Vector3.new(0, Flags.TPHeight, 0))
        end
    end)

    local c2 = char:GetAttributeChangedSignal("Released"):Connect(function()
        if Flags.TPAntiContest and char:GetAttribute("Released") and isTPd then
            holdUntil = tick() + (Flags.TPHoldTime or 0.5)
        end
    end)

    local hum = getHum(char)
    if hum then hum.Died:Once(function()
        c1:Disconnect(); c2:Disconnect()
        if holdConn then holdConn:Disconnect() end
        pcall(restore)
    end) end
end

