local function ToggleAutoFarm(v)
    Flags.AutoFarm = v
    if v then
        task.spawn(function()
            while Flags.AutoFarm do
                task.wait(0.15)
                
                local c = Player.Character
                local root = getRoot(c)
                if not root or not isActuallyPlaying(c) or ShotState.InProgress or ShotState.Paused then
                    continue
                end
                if tick() - inGameStamp < 3 then continue end

                local moveToPoint = c:GetAttribute("MoveToPoint")
                if moveToPoint and moveToPoint ~= Vector3.new(0, 0, 0) then
                    local target = Vector3.new(moveToPoint.X, root.Position.Y, moveToPoint.Z)
                    local distToPoint = (Vector3.new(root.Position.X, 0, root.Position.Z) - Vector3.new(moveToPoint.X, 0, moveToPoint.Z)).Magnitude
                    if distToPoint > 0.5 then
                        if Flags.FastTP then
                            fastTP(target, true)
                        else
                            local hum = getHum(c)
                            if hum then hum:MoveTo(target) end
                        end
                        continue
                    end
                end

                local action = c:GetAttribute("Action") or ""
                local hasBall = c:FindFirstChild("Ball") ~= nil

                if hasBall and (action == "" or action == "Dribbling" or action == "Idle") then
                    local targetPos, holdOverride
                    local isSmartSpot = Flags.FarmSpot == "Auto 3-Pointer" or Flags.FarmSpot == "Auto Mid-Range"
                    if isSmartSpot then
                        local dist = Flags.FarmSpot == "Auto 3-Pointer" and 50 or 30
                        targetPos = getSmartShootPos(dist)
                    else
                        local spot = SavedSpots[Flags.FarmSpot]
                        if spot then targetPos = spot.position end
                    end
                    
                    if not Flags.FarmAutoGreen then
                        holdOverride = 0.45
                    end

                    if targetPos then
                        if Flags.FastTP then
                            fastTP(targetPos, true)
                            task.wait(0.15)
                            executeShot(holdOverride)
                            task.wait(2)
                        else
                            local dist = (root.Position - targetPos).Magnitude
                            if dist > 3.5 then
                                local hum = getHum(c)
                                if hum then hum:MoveTo(targetPos) end
                                continue
                            else
                                root.AssemblyLinearVelocity = Vector3.zero
                                executeShot(holdOverride)
                                task.wait(2)
                            end
                        end
                    end
                elseif not hasBall and not ShotState.ReboundDebounce and Flags.AutoBallPickup then
                    local looseBall = getLooseBall()
                    if looseBall then
                        if Flags.FastTP then
                            fastTP(looseBall.Position, false)
                        else
                            local hum = getHum(c)
                            if hum then hum:MoveTo(looseBall.Position) end
                        end
                        task.wait(0.3)
                    end
                end
            end
        end)
    end
end

local function ToggleAutoMatch(v)
    Flags.AutoMatch = v
    if v and GetGameState().IsLobby then
        task.spawn(function()
            local lastQueueAttempt = 0

            while Flags.AutoMatch do
                task.wait(3)
                local c = Player.Character
                local root = getRoot(c)

                if not c or not root then continue end
                if isActuallyPlaying(c) then continue end
                if tick() - outGameStamp < 4 then continue end
                
                local isQueued = c:GetAttribute("Queued") or c:GetAttribute("InQueue") or (c:GetAttribute("State") == "Queue")
                if isQueued then continue end 

                local spot = get1v1Spot()
                if spot and (tick() - lastQueueAttempt > 5) then
                    
                    if Flags.FastTP then
                        root.CFrame = spot.CFrame + Vector3.new(0, 1, 0)
                        root.AssemblyLinearVelocity = Vector3.zero
                    else
                        local hum = getHum(c)
                        if hum then hum:MoveTo(spot.Position) end
                    end

                    task.wait(0.5)
                    
                    for _, prompt in pairs(workspace:GetDescendants()) do
                        if prompt:IsA("ProximityPrompt") and prompt.Parent then
                            if (prompt.Parent.Position - root.Position).Magnitude < 15 then
                                pcall(function() fireproximityprompt(prompt) end)
                            end
                        end
                    end

                    pcall(function()
                        local q = ReplicatedStorage:FindFirstChild("Queue")
                        if q then q:FireServer({ JoinQueue = true }) end
                    end)
                    
                    lastQueueAttempt = tick()
                end
            end
        end)
    end
end

