local function ToggleAutoGuard(v)
    Flags.AutoGuard = v
    if v then
        local guarding = false
        Conns.AutoGuard = RunService.Stepped:Connect(function()
            if not Flags.AutoGuard then return end
            local c = Player.Character
            if not c then return end
            local root = getRoot(c)
            if not root then return end
            local target = getNearestBallHandler()
            if target and target.Character then
                local tr = getRoot(target.Character)
                if tr then
                    if not guarding then
                        pcall(function() ActionRemote:FireServer({Action = "Guard", Guard = true}) end)
                        guarding = true
                    end
                    c:SetAttribute("Guarding", target.Name)
                    local hoopPos = getHoopPosition()
                    if hoopPos then
                        local guardPos = tr.Position + (hoopPos - tr.Position).Unit * Flags.GuardDistance
                        local goalCF = CFrame.new(guardPos, Vector3.new(tr.Position.X, guardPos.Y, tr.Position.Z))
                        if Flags.GuardSpeed >= 1 then root.CFrame = goalCF
                        else root.CFrame = root.CFrame:Lerp(goalCF, Flags.GuardSpeed) end
                        root.AssemblyLinearVelocity = Vector3.zero
                    end
                end
            else
                if guarding then
                    pcall(function() ActionRemote:FireServer({Action = "Guard", Guard = false}) end)
                    guarding = false
                    c:SetAttribute("Guarding", "")
                end
            end
        end)
    else
        if Conns.AutoGuard then Conns.AutoGuard:Disconnect(); Conns.AutoGuard = nil end
        pcall(function() ActionRemote:FireServer({Action = "Guard", Guard = false}) end)
    end
end

local function ToggleAutoSteal(v)
    Flags.AutoSteal = v
    if v then
        task.spawn(function()
            while Flags.AutoSteal do
                local c = Player.Character
                if c and not c:FindFirstChild("Ball") and getNearestBallHandler() then
                    pcall(function() ActionRemote:FireServer({Action = "Reach", Reach = true}) end)
                end
                task.wait(0.6)
            end
        end)
    end
end

local function ToggleAutoTime(v)
    Flags.AutoTime = v
    if v then
        Conns.AutoTime = UserInputService.InputBegan:Connect(function(input, gpe)
            if gpe or input.KeyCode ~= Enum.KeyCode.E then return end
            if not Flags.AutoTime or ShotState.InProgress then return end
            local c = Player.Character
            if not c or not c:FindFirstChild("Ball") then return end
            executeShot()
        end)
    else
        if Conns.AutoTime then Conns.AutoTime:Disconnect(); Conns.AutoTime = nil end
    end
end

