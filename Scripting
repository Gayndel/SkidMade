-- SAFE AUTOMATCH LOGIC WITH COOLDOWNS
-- ==========================================
UIElements.AutoMatch = GameR:AddToggle("AutoMatch", {
    Text    = "Auto Queue (1v1 Matchmaking)",
    Default = Flags.AutoMatch,
    Tooltip = "Waits safely for game end transition, then queues.",
    Callback = function(v)
        Flags.AutoMatch = v
        if v then
            task.spawn(function()
                local platform = workspace:FindFirstChild("GymOpPlatform")
                if not platform then
                    platform = Instance.new("Part"); platform.Name = "GymOpPlatform"; platform.Size = Vector3.new(15, 1, 15)
                    platform.Anchored = true; platform.Transparency = 1; platform.Parent = workspace
                end
                
                local wasInGame = false
                while Flags.AutoMatch do
                    local c = Player.Character
                    if c then
                        local inGame = c:GetAttribute("InGame")
                        local inQueue = c:GetAttribute("InQueue")
                        local currentlyInGame = (inGame and inGame ~= "")

                        if currentlyInGame then
                            wasInGame = true
                        elseif wasInGame and not currentlyInGame then
                            -- MATCH JUST ENDED: Wait a full 10 seconds to allow natural transition/fade out screen
                            wasInGame = false
                            task.wait(10)
                        elseif not currentlyInGame and not inQueue and not wasInGame then
                            -- IN LOBBY, NOT QUEUED: Time to enter the queue safely
                            local root = getRoot(c)
                            local spot = workspace:FindFirstChild("Spots") and workspace.Spots:FindFirstChild("1v1")
                            
                            if root and spot then
                                platform.CFrame = spot.CFrame + Vector3.new(0, -1, 0)
                                
                                -- Prevent physics flinging during teleport
                                root.AssemblyLinearVelocity = Vector3.zero
                                root.AssemblyAngularVelocity = Vector3.zero
                                root.CFrame = spot.CFrame + Vector3.new(0, 3, 0)
                                
                                task.wait(1) -- Short delay before firing the queue so the server registers your position
                                pcall(function()
                                    local q = ReplicatedStorage:FindFirstChild("Queue")
                                    if q then q:FireServer({ JoinQueue = true }) end
                                end)
                            end
                        end
                    end
                    task.wait(2) -- Run the check every 2 seconds instead of spamming
                end
            end)
        end
    end,
})

