AttrL:AddButton({ Text = "Upgrade All Categories", Func = function()
    task.spawn(function()
        local pd = Player:FindFirstChild("PlayerData"); if not pd then return end
        local slotFolder = pd.Slots:FindFirstChild(tostring(pd.CurrentSlot.Value)); if not slotFolder then return end
        local stats = slotFolder:FindFirstChild("Stats"); if not stats then return end
        local maxStats = slotFolder:FindFirstChild("MaxStats"); if not maxStats then return end
        local count = 0
        for cat, attrs in pairs(ATTR_CATEGORIES) do
            for _, attrName in pairs(attrs) do
                local cur = stats:FindFirstChild(attrName)
                local max = maxStats:FindFirstChild(attrName)
                if cur and max then
                    while cur.Value < max.Value do
                        pcall(function()
                            ReplicatedStorage.Remotes.Server:FindFirstChild("EditAttribute"):FireServer({Type="Upgrade", AttributeName=attrName})
                        end)
                        count = count + 1; task.wait(0.3)
                        if cur.Value >= max.Value then break end
                    end
                end
            end
        end
        Library:Notify({Title="Attributes",Description=count.." upgrades applied.",Duration=4})
    end)
