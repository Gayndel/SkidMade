local function getSavePath(name) return ConfigFolder .. "/" .. name .. ".json" end

local function LoadConfigByName(name)
    local file = getSavePath(name)
    if not isfile or not isfile(file) then return false end
    local config = HttpService:JSONDecode(readfile(file))
    if not config then return false end

    if config.Flags then
        for k, v in pairs(config.Flags) do
            if UI.Toggles[k] then UI.Toggles[k]:SetValue(v) end
            if UI.Options[k] then UI.Options[k]:SetValue(v) end
        end
    end
    if config.HoldTimes then for k, v in pairs(config.HoldTimes) do HoldTimes[k] = v end end
    if config.SavedSpots then
        for k, v in pairs(config.SavedSpots) do
            if v.position then SavedSpots[k].position = Vector3.new(v.position[1], v.position[2], v.position[3]) end
            if v.holdTime then SavedSpots[k].holdTime = v.holdTime end
        end
    end
    return true
end

