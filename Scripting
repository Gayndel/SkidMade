            Library:Notify({ Title = "Not a 1v1", Description = totalPlayers .. " players in this match. Leaving server.", Duration = 3 })
            task.wait(1)
            pcall(function() TeleportService:Teleport(LOBBY_PLACE_ID, Player) end)
        end
    end
end

