-- TP Anti-Contest setup
local function setupTPForChar(char)
    local root = char:WaitForChild("HumanoidRootPart", 5); if not root then return end
    local savedCF, isTPd = nil, false
    local function restore()
        if not isTPd then return end; isTPd = false
        root.Anchored = false; if not Flags.TPStayUp then root.CFrame = savedCF end; savedCF = nil
    end
    char:GetAttributeChangedSignal("Action"):Connect(function()
        if not Flags.TPAntiContest then return end
        local a = char:GetAttribute("Action") or ""
        if (a == "Shooting" or a == "Dunking") and not isTPd then savedCF = root.CFrame; root.Anchored = true; root.CFrame = savedCF + Vector3.new(0, Flags.TPHeight, 0); isTPd = true
        elseif (a == "" or a == "Dribbling" or a == "Idle") and isTPd then restore() end
    end)
    char:GetAttributeChangedSignal("Released"):Connect(function()
        if Flags.TPAntiContest and char:GetAttribute("Released") and isTPd then task.delay(0.15, restore) end
    end)
    local hum = getHum(char); if hum then hum.Died:Once(function() pcall(restore) end) end
end

