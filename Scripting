-- ═══ HELPERS ═══
local function getRoot(char) return char and char:FindFirstChild("HumanoidRootPart") end
local function getHum(char)  return char and char:FindFirstChildOfClass("Humanoid") end

local function isActuallyPlaying(char)
    if not char then return false end
    local inGame = char:GetAttribute("InGame")
    return inGame == true or (type(inGame) == "string" and inGame ~= "")
end

local function getShotType()
    local c = Player.Character
    if not c then return "default" end
    local st = c:GetAttribute("Action") or ""
    local gather = c:GetAttribute("GatherType") or ""
    
    if st == "Dunking" then return "Dunk" end
    if gather:find("Layup") then return "Layup" end
    if gather:find("Floater") then return "Floater" end
    if gather:find("PostHook") then return "PostHook" end
    if gather:find("PostFade") then return "PostFade" end
    
    local hum = getHum(c)
    if hum and hum.MoveDirection.Magnitude > 0.1 then return "Moving" end
    
    return "Standing"
end

local function getHoopGoal()
    local c = Player.Character
    if not c then return nil end
    local data = c:FindFirstChild("Data")
    if not data then return nil end
    local hoopVal = data:FindFirstChild("Hoop")
    if not hoopVal or not hoopVal.Value then return nil end
    return hoopVal.Value:FindFirstChild("Goal", true) or hoopVal.Value:FindFirstChild("RimMesh", true) or hoopVal.Value:FindFirstChild("Rim", true)
end

local function getHoopPosition()
    local goal = getHoopGoal()
    return goal and goal.Position or nil
end

local function getSmartShootPos(distFromHoop)
    local hoopPos = getHoopPosition()
    if not hoopPos then return nil end
    local root = getRoot(Player.Character)
    if not root then return nil end
    local dir = (root.Position - hoopPos) * Vector3.new(1, 0, 1)
    if dir.Magnitude < 0.5 then dir = Vector3.new(0, 0, 1) end
    dir = dir.Unit
    local ground = root.Position.Y
    return Vector3.new(hoopPos.X + dir.X * distFromHoop, ground, hoopPos.Z + dir.Z * distFromHoop)
end

local function getNearestBallHandler()
    local char = Player.Character
    if not char then return nil end
    local root = getRoot(char)
    if not root then return nil end
    local myCourt = char:GetAttribute("InGame") or ""
    if myCourt == "" then return nil end
    local myTeam = Player:GetAttribute("Team") or Player:GetAttribute("PlrTeam") or (Player.Team and Player.Team.Name)
    local nearest, dist = nil, math.huge
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= Player and p.Character and p.Character:FindFirstChild("Ball") then
            local theirCourt = p.Character:GetAttribute("InGame") or ""
            if theirCourt ~= myCourt then continue end
            local theirTeam = p:GetAttribute("Team") or p:GetAttribute("PlrTeam") or (p.Team and p.Team.Name)
            if theirTeam ~= myTeam then
                local r = getRoot(p.Character)
                if r then
                    local d = (r.Position - root.Position).Magnitude
                    if d < dist then dist = d; nearest = p end
                end
            end
        end
    end
    return nearest
end

local function getLooseBall()
    local char = Player.Character
    if not char then return nil end
    local root = getRoot(char)
    if not root then return nil end
    local hoopPos = getHoopPosition()
    if not hoopPos then return nil end
    local nearest, dist = nil, math.huge
    for _, obj in pairs(workspace:GetDescendants()) do
        if obj.Name == "Ball" and obj:IsA("BasePart") and not obj.Anchored then
            local parentName = obj.Parent and obj.Parent.Name or ""
            if parentName == "AnimRig" or parentName == "AnimationRig" then continue end
            local held = false
            for _, p in pairs(Players:GetPlayers()) do
                if p.Character and p.Character:FindFirstChild("Ball") == obj then held = true; break end
            end
            if not held then
                local ballToHoop = (obj.Position - hoopPos).Magnitude
                if ballToHoop > 60 then continue end
                local d = (obj.Position - root.Position).Magnitude
                if math.abs(obj.Position.Y - root.Position.Y) > 20 or d > 50 then continue end
                if d < dist then dist = d; nearest = obj end
            end
        end
    end
    return nearest
end

local function fastTP(targetPos, lookAtGoal)
    local c = Player.Character
    if not c then return false end
    local root = getRoot(c)
    if not root then return false end

    root.AssemblyLinearVelocity = Vector3.zero
    root.AssemblyAngularVelocity = Vector3.zero

    if lookAtGoal then
        local goal = getHoopPosition()
        if goal then
            root.CFrame = CFrame.new(targetPos, Vector3.new(goal.X, targetPos.Y, goal.Z))
            return true
        end
    end
    root.CFrame = CFrame.new(targetPos)
    return true
end

local function get1v1Spot()
    local s = workspace:FindFirstChild("Spots") and workspace.Spots:FindFirstChild("1v1")
    if s then return s end
    
    local map = workspace:FindFirstChild("Map")
    if map then
        local mapSpots = map:FindFirstChild("Spots")
        if mapSpots and mapSpots:FindFirstChild("1v1") then return mapSpots["1v1"] end
    end

    for _, obj in pairs(workspace:GetDescendants()) do
        if obj:IsA("ProximityPrompt") then
            local txt = string.lower(obj.ActionText .. " " .. obj.ObjectText)
            if txt:find("1v1") then return obj.Parent end
        end
    end
    return nil
end

-- ═══ SHOT LOGIC & UI DETECTION OVERRIDE ═══
local function getRealTiming(c, rawTiming)
    if not c then return string.upper(rawTiming or "UNKNOWN") end
    local t = string.lower(rawTiming or "")
    
    if t == "perfect" or t == "green" or t == "excellent" then return "PERFECT" end
    
    local isPerfect = false
    
    local perc = tonumber(c:GetAttribute("ShotPercentage")) or tonumber(c:GetAttribute("Percentage"))
    if perc and perc >= 100 then isPerfect = true end
    if c:GetAttribute("Green") == true then isPerfect = true end
    
    if not isPerfect then
        pcall(function()
            local pgui = Player:FindFirstChild("PlayerGui")
            if pgui then
                for _, ui in pairs(pgui:GetDescendants()) do
                    if ui:IsA("TextLabel") and ui.Visible and ui.TextTransparency < 1 then
                        local txt = string.upper(ui.Text)
                        if txt == "PERFECT" or string.match(txt, "SHOT PERCENTAGE:%s*100%%") then
                            isPerfect = true
                            break
                        end
                    end
                end
            end
        end)
    end
    
    if isPerfect then return "PERFECT" end
    return string.upper(rawTiming)
end

local function adjustTiming(timing, shotType)
    local t = string.lower(timing or "")
    if t == "" or t == "default" or t == "perfect" or t == "good" then return 0 end
    
    local old = HoldTimes[shotType] or 0.45
    local delta = 0
    
    if t == "very early" then delta = 0.08
    elseif t == "early" then delta = 0.05
    elseif t == "slightly early" then delta = 0.01
    elseif t == "slightly late" then delta = -0.01
    elseif t == "late" then delta = -0.05
    elseif t == "very late" then delta = -0.08
    end

    if delta ~= 0 then
        HoldTimes[shotType] = math.clamp(old + delta, 0.15, 2.0)
    end
    return delta
end

local function handleShotResult(c, holdTime, shotType)
    local rawTiming = c:GetAttribute("Timing")
    if not rawTiming then return end
    if string.lower(rawTiming) == "default" then return end

    local realTiming = getRealTiming(c, rawTiming)

    local delta = 0
    local isPerfect = (realTiming == "PERFECT")
    
    if isPerfect then
        HoldTimes[shotType] = holdTime
        Flags.ScoreTracker = Flags.ScoreTracker + 1
    elseif Flags.SmartAI then
        delta = adjustTiming(rawTiming, shotType)
    end

    if Flags.ShotFeedbackHUD then
        local title = realTiming .. " | " .. string.upper(shotType)
        local desc = "Hold: " .. string.format("%.3fs", holdTime)
        
        if Flags.SmartAI and delta ~= 0 then
            local sign = delta > 0 and "+" or ""
            desc = desc .. " | Adj: " .. sign .. string.format("%.3f", delta) .. "s → " .. string.format("%.3f", HoldTimes[shotType]) .. "s"
        end
        
        Library:Notify({ Title = title, Description = desc, Duration = Flags.FeedbackDuration or 3 })
    end
end

local function executeShot(holdTimeOverride)
    local c = Player.Character
    if not c or not c:FindFirstChild("Ball") or ShotState.InProgress then return end
    local action = c:GetAttribute("Action") or ""
    if action == "Shooting" or action == "Dunking" then return end

    ShotState.InProgress = true
    ShotState.ReboundDebounce = true
    
    ShotState.LastType = getShotType()
    local holdTime = holdTimeOverride or HoldTimes[ShotState.LastType] or 0.45

    pcall(function() ActionRemote:FireServer({ Type = "Shoot", Shoot = true, HoldingQ = UserInputService:IsKeyDown(Enum.KeyCode.Q), HoldingL1 = false }) end)

    task.delay(holdTime, function()
        if not ShotState.InProgress then return end
        pcall(function() ActionRemote:FireServer({Type = "Shoot", Shoot = false}) end)
    end)

    task.spawn(function()
        local timeout = tick() + 4
        repeat task.wait(0.05) until c:GetAttribute("Released") == true or tick() > timeout or not c.Parent
        
        task.wait(0.1) 
        handleShotResult(c, holdTime, ShotState.LastType)
        task.wait(1.5)
        ShotState.ReboundDebounce = false
        ShotState.InProgress = false
    end)
end

