local guardingState = false
RunService.Stepped:Connect(function()
    if not Flags.AutoGuard then
        if guardingState then pcall(function() ActionRemote:FireServer({Action="Guard", Guard=false}) end); guardingState = false; local c = Player.Character; if c then c:SetAttribute("Guarding", "") end end
        return
    end
    local c = Player.Character; if not c then return end
    local root = getRoot(c); if not root then return end
    local target = getNearestBallHandler()
    if target and target.Character then
        local tr = getRoot(target.Character)
        if tr then
            if not guardingState then pcall(function() ActionRemote:FireServer({Action="Guard", Guard=true}) end); guardingState = true end
            c:SetAttribute("Guarding", target.Name)
            local hoopPos = getHoopPosition()
            if hoopPos then
                local dirToHoop = (hoopPos - tr.Position).Unit
                local guardPos = tr.Position + dirToHoop * Flags.GuardDistance
                local goalCF = CFrame.new(guardPos, Vector3.new(tr.Position.X, guardPos.Y, tr.Position.Z))
                if Flags.GuardSpeed >= 1 then root.CFrame = goalCF else root.CFrame = root.CFrame:Lerp(goalCF, Flags.GuardSpeed) end
                root.AssemblyLinearVelocity = Vector3.zero
            end
        end
    else
        if guardingState then pcall(function() ActionRemote:FireServer({Action="Guard", Guard=false}) end); guardingState = false; c:SetAttribute("Guarding", "") end
    end
end)

RunService.Stepped:Connect(function()
    local c = Player.Character; if not c then return end
    if Flags.SpeedEnabled then
        local hum = getHum(c)
        if hum and hum.MoveDirection.Magnitude > 0 then hum.WalkSpeed = 16 * Flags.SpeedMult end
    end
    if Flags.Noclip then
        for _, part in pairs(c:GetDescendants()) do if part:IsA("BasePart") then part.CanCollide = false end end
    end
end)

RunService.Heartbeat:Connect(function()
    local c = Player.Character; if not c then return end
    if Flags.SpeedEnabled then
        local root = getRoot(c); local hum = getHum(c)
        if root and hum and not root.Anchored then
            local bv = root:FindFirstChild("BodyVelocity")
            if bv and hum.MoveDirection.Magnitude > 0 then bv.MaxForce = Vector3.new(99999, 0, 99999); bv.Velocity = hum.MoveDirection * (30 * Flags.SpeedMult) end
        end
    end
    if Flags.InfiniteStamina then c:SetAttribute("Stamina", 100) end
end)

local function setupTPForChar(char)
    local root = char:WaitForChild("HumanoidRootPart", 5); if not root then return end
    local savedCF, isTPd = nil, false
    local function restore()
        if not isTPd then return end; isTPd = false
        if Flags.TPStayUp then root.Anchored = false; savedCF = nil else root.Anchored = false; root.CFrame = savedCF; savedCF = nil end
    end
    char:GetAttributeChangedSignal("Action"):Connect(function()
        if not Flags.TPAntiContest then return end
        local a = char:GetAttribute("Action") or ""
        if (a == "Shooting" or a == "Dunking") and not isTPd then savedCF = root.CFrame; root.Anchored = true; root.CFrame = savedCF + Vector3.new(0, Flags.TPHeight, 0); isTPd = true elseif (a == "" or a == "Dribbling" or a == "Idle") and isTPd then restore() end
    end)
    char:GetAttributeChangedSignal("Released"):Connect(function()
        if not Flags.TPAntiContest then return end
        if char:GetAttribute("Released") and isTPd then task.delay(0.15, restore) end
    end)
    local hum = getHum(char); if hum then hum.Died:Once(function() pcall(restore) end) end
end

