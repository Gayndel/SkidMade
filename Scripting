        config.SavedSpots[k] = { position = {v.position.X, v.position.Y, v.position.Z}, holdTime = v.holdTime, scoreType = v.scoreType, distance = v.distance } 
    end
    
    if writefile then 
        writefile(getSavePath(name), HttpService:JSONEncode(config))
        Library:Notify({ Title = "Config Saved", Description = "Saved as: " .. name, Duration = 3 })
        Flags.NewConfigName = "" 
        RefreshDropdown()
        ConfigDrop:SetValue(name)
    end
end})

