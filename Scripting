local function getConfigName()
    local name = Flags.ConfigName
    if not name or name == "" then name = "default" end
    return "GymBasketballOP_" .. name .. ".json"
end

local function getAvailableConfigs()
    local list = {"default"}
    if listfiles then
        local s, files = pcall(function() return listfiles("") end)
        if s and type(files) == "table" then
            for _, file in pairs(files) do
                local name = file:match("GymBasketballOP_(.*)%.json")
                if name and name ~= "default" then
                    table.insert(list, name)
                end
            end
        end
    end
    return list
end

local function saveConfig(silent)
    local ConfigFile = getConfigName()
    local config = { Flags = {}, HoldTimes = HoldTimes, SavedSpots = {} }
    for k, v in pairs(Flags) do
        if type(v) == "boolean" or type(v) == "number" or type(v) == "string" then
            config.Flags[k] = v
        end
    end
    for k, v in pairs(SavedSpots) do
        config.SavedSpots[k] = {
            position = {v.position.X, v.position.Y, v.position.Z},
            holdTime = v.holdTime, scoreType = v.scoreType, distance = v.distance,
        }
    end
    local json = HttpService:JSONEncode(config)
    if writefile then
        writefile(ConfigFile, json)
        if not silent then Library:Notify({ Title = "Config", Description = "Saved: " .. ConfigFile, Duration = 3 }) end
    end
end

local function loadConfig(fileNameOverride, silent)
    local ConfigFile = fileNameOverride or getConfigName()
    if not isfile or not isfile(ConfigFile) then
        if not silent then Library:Notify({ Title = "Config", Description = "Not found: " .. ConfigFile, Duration = 3 }) end
        return false
    end
    local json = readfile(ConfigFile)
    if not json then return false end
    local ok, config = pcall(function() return HttpService:JSONDecode(json) end)
    if not ok or not config then return false end
    if config.Flags then for k, v in pairs(config.Flags) do Flags[k] = v end end
    if config.HoldTimes then for k, v in pairs(config.HoldTimes) do HoldTimes[k] = v end end
    if config.SavedSpots then
        for k, v in pairs(config.SavedSpots) do
            if v.position and type(v.position) == "table" then
                SavedSpots[k] = {
                    position = Vector3.new(v.position[1], v.position[2], v.position[3]),
                    holdTime = v.holdTime, scoreType = v.scoreType, distance = v.distance,
                }
            end
        end
    end
    if not silent then Library:Notify({ Title = "Config", Description = "Loaded: " .. ConfigFile, Duration = 3 }) end
    return true
end

