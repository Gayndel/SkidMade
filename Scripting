            if c:GetAttribute("SecondPushStun")  then c:SetAttribute("SecondPushStun", false) end
            if c:GetAttribute("RecentlyPushed")  then c:SetAttribute("RecentlyPushed", false) end
            if c:GetAttribute("Pushed")          then c:SetAttribute("Pushed", false) end
        end
    end
end)

