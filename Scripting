local function getSavePath(name) return ConfigFolder .. "/" .. name .. ".json" end
local SKIP_SAVE_KEYS = { ConfigName = true, NewConfigName = true, ScoreTracker = true }

local function SaveConfigData(name)
    if not name or name == "" then return false end
    
    local saveable = {}
    for k, v in pairs(Flags) do
        if not SKIP_SAVE_KEYS[k] and (type(v) == "boolean" or type(v) == "number" or type(v) == "string") then
            saveable[k] = v
        end
    end

    local config = { Flags = saveable, HoldTimes = HoldTimes, SavedSpots = {} }
    
    for k, v in pairs(SavedSpots) do
        config.SavedSpots[k] = { 
            position = v.position and {v.position.X, v.position.Y, v.position.Z} or {0,0,0}, 
            scoreType = v.scoreType or 2, 
            distance = v.distance or 30 
        }
    end

    SafeMakeFolder(ConfigFolder)
    local success, err = pcall(function()
        writefile(getSavePath(name), HttpService:JSONEncode(config))
    end)
    
    return success
end

