local function ToggleAutoFarm(v)
    Flags.AutoFarm = v
    if v then
        task.spawn(function()
            local lastGuardFire = 0
            local lastReachFire = 0
            while Flags.AutoFarm do
                task.wait()
                local c = Player.Character
                local root = getRoot(c)
                if not root or not isActuallyPlaying(c) or ShotState.InProgress or ShotState.Paused then
                    task.wait(0.5); continue
                end

                local action = c:GetAttribute("Action") or ""
                local hasBall = c:FindFirstChild("Ball") ~= nil

                if hasBall and (action == "" or action == "Dribbling" or action == "Idle") then
                    local spot = SavedSpots[Flags.FarmSpot]
                    if spot then
                        local dist = (root.Position - spot.position).Magnitude
                        if Flags.FastTP then
                            fastTP(spot.position, true)
                            task.wait(0.15)
                            executeShot(spot.holdTime)
                            task.wait(2)
                        else
                            if dist > 3.5 then
                                local hum = getHum(c)
                                if hum then hum:MoveTo(spot.position) end
                                task.wait(0.1)
                                continue
                            else
                                root.AssemblyLinearVelocity = Vector3.zero
                                executeShot(spot.holdTime)
                                task.wait(2)
                            end
                        end
                    end
                elseif not hasBall and not ShotState.ReboundDebounce and Flags.AutoBallPickup then
                    local looseBall = getLooseBall()
                    if looseBall then
                        local ballDist = (root.Position - looseBall.Position).Magnitude
                        if Flags.FastTP then
                            fastTP(looseBall.Position + Vector3.new(0, 3, 0), false)
                        else
                            local hum = getHum(c)
                            if hum and ballDist > 4 then hum:MoveTo(looseBall.Position) end
                        end
                        if tick() - lastReachFire > 0.3 and ballDist < 10 then
                            pcall(function() ActionRemote:FireServer({Action="Reach", Reach=true}) end)
                            lastReachFire = tick()
                        end
                    else
                        local handler = getNearestBallHandler()
                        if handler and handler.Character then
                            local tr = getRoot(handler.Character)
                            if tr then
                                local handDist = (root.Position - tr.Position).Magnitude
                                if Flags.FastTP then
                                    local hoopPos = getHoopPosition()
                                    if hoopPos then
                                        local dir = (hoopPos - tr.Position).Unit
                                        local guardPos = tr.Position + dir * Flags.GuardDistance
                                        root.CFrame = CFrame.new(guardPos, Vector3.new(tr.Position.X, guardPos.Y, tr.Position.Z))
                                    else
                                        fastTP(tr.Position + Vector3.new(0,0,Flags.GuardDistance), false)
                                    end
                                else
                                    local hum = getHum(c)
                                    if hum and handDist > Flags.GuardDistance then hum:MoveTo(tr.Position) end
                                end
                                if tick() - lastGuardFire > 0.5 and handDist < 12 then
                                    pcall(function() ActionRemote:FireServer({Action="Guard", Guard=true}) end)
                                    c:SetAttribute("Guarding", handler.Name)
                                    lastGuardFire = tick()
                                end
                            end
                        end
                    end
                end
            end
        end)
    end
end

local function ToggleAutoMatch(v)
    Flags.AutoMatch = v
    if v then
        task.spawn(function()
            local inQueueWait = false
            local lastQueueAttempt = 0

            while Flags.AutoMatch do
                task.wait(1)
                local c = Player.Character
                local root = getRoot(c)

                if not c or not root then inQueueWait = false; continue end
                if isActuallyPlaying(c) then inQueueWait = false; continue end
                if c:GetAttribute("Queued") or c:GetAttribute("InQueue") or c:GetAttribute("State") == "Queue" then
                    inQueueWait = true
                end

                if inQueueWait then continue end

                local spot = workspace:FindFirstChild("Spots") and workspace.Spots:FindFirstChild("1v1")
                if spot and (tick() - lastQueueAttempt > 5) then
                    if Flags.FastTP then
                        root.CFrame = spot.CFrame + Vector3.new(0, 3, 0)
                    else
                        local hum = getHum(c)
                        if hum then hum:MoveTo(spot.Position) end
                    end
                    
                    if (root.Position - spot.Position).Magnitude < 10 then
                        task.wait(0.5)
                        pcall(function()
                            local q = ReplicatedStorage:FindFirstChild("Queue")
                            if q then 
                                q:FireServer({ JoinQueue = true })
                                lastQueueAttempt = tick()
                                inQueueWait = true
                            end
                        end)
                    end
                end
            end
        end)
    end
end

