-- AUTO FARM CORE
-- ═══════════════════════════════════════════════════════════════
local function runAutoFarm()
    task.spawn(function()
        local lastGuardFire, lastReachFire = 0, 0
        while Flags.AutoFarm do
            local c = Player.Character; if not c then task.wait(0.5); continue end
            local root = getRoot(c); if not root then task.wait(0.5); continue end
            local inGame = c:GetAttribute("InGame")
            if not inGame or inGame == "" then task.wait(1); continue end
            if ShotInProgress or FarmingPaused then task.wait(0.2); continue end

            local action = c:GetAttribute("Action") or ""
            local hasBall = c:FindFirstChild("Ball") ~= nil

            if hasBall and (action == "" or action == "Dribbling" or action == "Idle") then
                local spot = SavedSpots[Flags.FarmSpot]
                if spot then
                    if Flags.FastTP then fastTP(spot.position, true) end
                    task.wait(0.15); executeShot(spot.holdTime); task.wait(2) 
                end
            elseif not hasBall and not ReboundDebounce and Flags.AutoBallPickup then
                local looseBall = getLooseBall()
                if looseBall then
                    if Flags.FastTP then fastTP(looseBall.Position + Vector3.new(0, 3, 0), false) end
                    if tick() - lastReachFire > 0.3 then pcall(function() ActionRemote:FireServer({Action="Reach", Reach=true}) end); lastReachFire = tick() end
                else
                    local ballHandler = getNearestBallHandler()
                    if ballHandler and ballHandler.Character then
                        local tr = getRoot(ballHandler.Character)
                        if tr and Flags.FastTP then
                            local hoopPos = getHoopPosition()
                            if hoopPos then
                                local dirToHoop = (hoopPos - tr.Position).Unit
                                local guardPos = tr.Position + dirToHoop * Flags.GuardDistance
                                local goalCF = CFrame.new(guardPos, Vector3.new(tr.Position.X, guardPos.Y, tr.Position.Z))
                                if Flags.GuardSpeed >= 1 then root.CFrame = goalCF else root.CFrame = root.CFrame:Lerp(goalCF, Flags.GuardSpeed) end
                                root.AssemblyLinearVelocity = Vector3.zero
                            else fastTP(tr.Position + Vector3.new(0, 0, Flags.GuardDistance), false) end
                        end
                        if tick() - lastGuardFire > 0.5 then
                            pcall(function() ActionRemote:FireServer({Action="Guard", Guard=true}) end)
                            c:SetAttribute("Guarding", ballHandler.Name); lastGuardFire = tick()
                        end
                    else task.wait(0.5) end
                end
            end
            task.wait()
        end
    end)
end

-- ═══ TP ANTI-CONTEST ═══
local function setupTPForChar(char)
    local root = char:WaitForChild("HumanoidRootPart", 5); if not root then return end
    local savedCF, isTPd = nil, false
    local function restore()
        if not isTPd then return end; isTPd = false
        if Flags.TPStayUp then root.Anchored = false; savedCF = nil else root.Anchored = false; root.CFrame = savedCF; savedCF = nil end
    end
    local c1 = char:GetAttributeChangedSignal("Action"):Connect(function()
        if not Flags.TPAntiContest then return end
        local a = char:GetAttribute("Action") or ""
        if (a == "Shooting" or a == "Dunking") and not isTPd then savedCF = root.CFrame; root.Anchored = true; root.CFrame = savedCF + Vector3.new(0, Flags.TPHeight, 0); isTPd = true
        elseif (a == "" or a == "Dribbling" or a == "Idle") and isTPd then restore() end
    end)
    local c2 = char:GetAttributeChangedSignal("Released"):Connect(function()
        if not Flags.TPAntiContest then return end
        if char:GetAttribute("Released") and isTPd then task.delay(0.15, restore) end
    end)
    local hum = getHum(char); if hum then hum.Died:Once(function() c1:Disconnect(); c2:Disconnect(); pcall(restore) end) end
end

-- ═══ ANTI-STUN ═══
