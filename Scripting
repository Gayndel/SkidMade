local function countPlayersInGame()
    local count = 0
    for _, p in pairs(Players:GetPlayers()) do
        if p.Character then
            local inGame = p.Character:GetAttribute("InGame")
            if inGame and inGame ~= "" then
                count = count + 1
            end
        end
    end
    return count
end

local function leaveQueue()
    pcall(function() QueueRemote:FireServer({LeaveQueue = true}) end)
end

local function joinQueue1v1()
    local c = Player.Character
    if not c then return end
    local root = getRoot(c)
    if not root then return end
    root.CFrame = CFrame.new(SPOT_1V1 + Vector3.new(0, 3, 0))
    root.AssemblyLinearVelocity = Vector3.zero
    task.wait(0.3)
    pcall(function() QueueRemote:FireServer({JoinQueue = true}) end)
end

