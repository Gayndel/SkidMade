    end)
end

SafeMakeFolder(ConfigFolder)

local function GetAvailableConfigs()
    local list = {}
    pcall(function()
        if listfiles then
            for _, file in ipairs(listfiles(ConfigFolder)) do
                if file:sub(-5) == ".json" then
                    local name = file:match("([^/\\]+)%.json$")
                    if name then table.insert(list, name) end
                end
            end
        end
    end)
    return list
end

