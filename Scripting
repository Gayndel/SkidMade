end

local function adjustTiming(timing, shotType)
    if not timing or timing == "DEFAULT" or timing == "PERFECT" then return end
    local step = Flags.AdjustStep; local delta = 0
    if timing == "Very Early" then delta = step elseif timing == "Slightly Early" then delta = step * 0.6 elseif timing == "Early" then delta = step * 0.4 elseif timing == "Good" then delta = step * 0.2 elseif timing == "Slightly Late" then delta = -step * 0.6 elseif timing == "Late" then delta = -step * 0.4 elseif timing == "Very Late" then delta = -step end
    HoldTimes[shotType] = math.clamp((HoldTimes[shotType] or HoldTimes.default) + delta, 0.15, 2.0)
    ShotCounts[shotType] = (ShotCounts[shotType] or 0) + 1
end

local function executeShot(holdTimeOverride)
    local c = Player.Character; if not c or not c:FindFirstChild("Ball") then return end
    if ShotInProgress then return end
    local action = c:GetAttribute("Action") or ""; if action == "Shooting" or action == "Dunking" then return end
    ShotInProgress = true; ReboundDebounce = true; LastShotType = getShotType()
    local holdTime = holdTimeOverride or HoldTimes[LastShotType] or HoldTimes.default
    pcall(function() ActionRemote:FireServer({Type="Shoot", Shoot=true, HoldingQ=UserInputService:IsKeyDown(Enum.KeyCode.Q), HoldingL1=false}) end)
    task.delay(holdTime, function() if ShotInProgress then pcall(function() ActionRemote:FireServer({Type="Shoot", Shoot=false}) end) end end)
    task.spawn(function()
        local timeout = tick() + 4
        repeat task.wait(0.05) until c:GetAttribute("Released") == true or tick() > timeout or not c.Parent
        local timing = c:GetAttribute("Timing")
        if timing and timing ~= "DEFAULT" then
            if Flags.SmartAI then adjustTiming(timing, LastShotType) end
            if timing == "PERFECT" then HoldTimes[LastShotType] = holdTime; Flags.ScoreTracker = Flags.ScoreTracker + 1 end
            if Flags.ShotFeedbackHUD then showFeedback(timing, holdTime) end
        end
        task.wait(1.5); ReboundDebounce = false; ShotInProgress = false
    end)
end

-- ═══ BADGE DATA ═══
local CachedBadgeList = {}

local function refreshBadgeData()
    pcall(function()
        local data = GetDataRemote:InvokeServer()
        if not data then return end
        local slot = data.Slots[tostring(data.CurrentSlot)]
        if not slot or not slot.Badges then return end
        CachedBadgeList = {}
        for name, info in pairs(slot.Badges) do
            table.insert(CachedBadgeList, {
                name = name, currentTier = info.CurrentTier, maxTier = info.MaxTier,
                category = BADGE_TO_CATEGORY[name] or "Unknown",
            })
        end
        table.sort(CachedBadgeList, function(a, b) return a.name < b.name end)
    end)
end

local function getUpgradeableBadges(category)
    local result = {}
    for _, badge in pairs(CachedBadgeList) do
        if badge.maxTier > 0 and badge.currentTier < badge.maxTier then
            if category == "All" or badge.category == category then
                table.insert(result, badge.name)
            end
        end
    end
    table.sort(result)
    return result
end

local function getBadgePointsForCategory(category)
    local data = GetDataRemote:InvokeServer()
    if not data then return 0 end
    local slot = data.Slots[tostring(data.CurrentSlot)]
    if not slot or not slot.BadgePoints or not slot.BadgePoints[category] then return 0 end
    return slot.BadgePoints[category].BadgePoints or 0
end

