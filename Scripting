-- ═══ SHOT LOGIC ═══
local function adjustTiming(timing, shotType)
    if not timing or timing == "DEFAULT" or timing == "PERFECT" then return end
    local step = Flags.AdjustStep
    local delta = 0
    if timing == "Very Early" then delta = step elseif timing == "Slightly Early" then delta = step * 0.6
    elseif timing == "Early" then delta = step * 0.4 elseif timing == "Good" then delta = step * 0.2
    elseif timing == "Slightly Late" then delta = -step * 0.6 elseif timing == "Late" then delta = -step * 0.4
    elseif timing == "Very Late" then delta = -step end
    HoldTimes[shotType] = math.clamp((HoldTimes[shotType] or 0.55) + delta, 0.15, 2.0)
end

local function executeShot(holdTimeOverride)
    local c = Player.Character
    if not c or not c:FindFirstChild("Ball") or ShotState.InProgress then return end
    local action = c:GetAttribute("Action") or ""
    if action == "Shooting" or action == "Dunking" then return end

    ShotState.InProgress = true
    ShotState.ReboundDebounce = true 
    ShotState.LastType = getShotType()
    local holdTime = holdTimeOverride or HoldTimes[ShotState.LastType] or 0.55

    pcall(function() ActionRemote:FireServer({ Type = "Shoot", Shoot = true, HoldingQ = UserInputService:IsKeyDown(Enum.KeyCode.Q), HoldingL1 = false }) end)

    task.delay(holdTime, function()
        if not ShotState.InProgress then return end
        pcall(function() ActionRemote:FireServer({Type = "Shoot", Shoot = false}) end)
    end)

    task.spawn(function()
        local timeout = tick() + 4
        repeat task.wait(0.05) until c:GetAttribute("Released") == true or tick() > timeout or not c.Parent

        local timing = c:GetAttribute("Timing")
        if timing and timing ~= "DEFAULT" then
            if Flags.SmartAI then adjustTiming(timing, ShotState.LastType) end
            if timing == "PERFECT" then
                HoldTimes[ShotState.LastType] = holdTime
                Flags.ScoreTracker = Flags.ScoreTracker + 1
            end
            if Flags.ShotFeedbackHUD then showFeedback(timing, holdTime) end
        end
        task.wait(1.5)
        ShotState.ReboundDebounce = false
        ShotState.InProgress = false
    end)
end

