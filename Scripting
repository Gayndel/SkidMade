        local stats = slotFolder:FindFirstChild("Stats"); if not stats then return end
        local maxStats = slotFolder:FindFirstChild("MaxStats"); if not maxStats then return end
        local lines = {}
        for _, s in pairs(stats:GetChildren()) do
            local max = maxStats:FindFirstChild(s.Name)
            local maxVal = max and max.Value or "?"
            local status = (s.Value >= (max and max.Value or 999)) and " ✓" or ""
            table.insert(lines, s.Name .. ": " .. s.Value .. " / " .. maxVal .. status)
        end
        table.sort(lines)
        Library:Notify({Title="Attributes",Description=table.concat(lines, "\n"),Duration=10})
    end)
end })

