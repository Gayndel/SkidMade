local function LoadConfigByName(name)
    if not name or name == "" then return false end
    local file = getSavePath(name)
    
    local success, fileData = pcall(function()
        if isfile and not isfile(file) then return nil end
        return readfile(file)
    end)
    
    if not success or not fileData then return false end
    
    local ok, config = pcall(function() return HttpService:JSONDecode(fileData) end)
    if not ok or not config then return false end

    if config.Flags then
        for k, v in pairs(config.Flags) do
            if UI.Toggles[k] then UI.Toggles[k]:SetValue(v) end
            if UI.Options[k] then UI.Options[k]:SetValue(v) end
        end
    end
    if config.HoldTimes then
        for k, v in pairs(config.HoldTimes) do HoldTimes[k] = v end
        Env._configLoaded = true
    end
    if config.SavedSpots then
        for k, v in pairs(config.SavedSpots) do
            if v.position then
                SavedSpots[k] = SavedSpots[k] or {}
                SavedSpots[k].position = Vector3.new(v.position[1], v.position[2], v.position[3])
            end
            if v.scoreType then SavedSpots[k].scoreType = v.scoreType end
            if v.distance then SavedSpots[k].distance = v.distance end
        end
    end
    return true
end

