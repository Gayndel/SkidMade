local DashData = { coins = 0, wins = 0, losses = 0, ovr = 0, streak = 0, greens = 0, slot = 1 }

local function refreshDashData()
    pcall(function()
        local pd = Player:FindFirstChild("PlayerData"); if not pd then return end
        local main = pd:FindFirstChild("Main"); if not main then return end
        DashData.coins  = main:FindFirstChild("Coins") and math.floor(main.Coins.Value) or 0
        DashData.wins   = main:FindFirstChild("Wins") and main.Wins.Value or 0
        DashData.losses = main:FindFirstChild("Losses") and main.Losses.Value or 0
        DashData.streak = main:FindFirstChild("Streak") and main.Streak.Value or 0
        DashData.slot   = pd:FindFirstChild("CurrentSlot") and pd.CurrentSlot.Value or 1
        local slot = pd.Slots:FindFirstChild(tostring(DashData.slot))
        if slot and slot:FindFirstChild("Stats") and slot:FindFirstChild("MinStats") and slot:FindFirstChild("MaxStats") then
            if _G.CalculateOverallRating then
                DashData.ovr = _G.CalculateOverallRating(slot.Stats, slot.MinStats, slot.MaxStats)
            else
                local total, count = 0, 0
                for _, s in pairs(slot.Stats:GetChildren()) do
                    if s:IsA("NumberValue") or s:IsA("IntValue") then total = total + s.Value; count = count + 1 end
                end
                DashData.ovr = count > 0 and math.floor(total / count) or 0
            end
        end
        DashData.greens = Flags.ScoreTracker
    end)
end

